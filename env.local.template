# ============================================
# Happy Optics Campaign - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# Command: cp env.local.template .env.local
# DO NOT commit .env.local to git!

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from: Supabase Dashboard → Settings → API
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings → API
# 4. Copy the values below

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Authentication (REQUIRED)
# ============================================
# Generate JWT Secret:
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use: openssl rand -hex 32
# Minimum 32 characters recommended

JWT_SECRET=your-generated-jwt-secret-minimum-32-characters-long

# ============================================
# Site Configuration (OPTIONAL)
# ============================================
# Your production domain (for SEO and links)
# For local development, use: http://localhost:3000
# For production, use: https://your-domain.com

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Twilio SMS Configuration (OPTIONAL)
# ============================================
# Only needed if you want to send SMS reminders for appointments
# Get from: https://www.twilio.com/console
# Leave empty if you don't need SMS reminders

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# Notes
# ============================================
# - SUPABASE_SERVICE_ROLE_KEY is SECRET - never share it!
# - JWT_SECRET should be a long, random string
# - Keep this file secure and never commit to git
# - .env.local is already in .gitignore

